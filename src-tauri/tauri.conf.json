{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MutinyChat",
  "version": "0.1.0",
  "identifier": "io.mutinychat.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build && npm run build:backend:sidecar",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "MutinyChat",
        "width": 1000,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "copyright": "Copyright (c) 2026 MutinyChat",
    "externalBin": [
      "../backend/dist/mutinychat-backend",
      "../backend/dist/tor"
    ],
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
